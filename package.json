{
  "name": "solana-upgrade-safety-skill",
  "version": "0.1.3",
  "description": "Tells you whether an Anchor program upgrade will corrupt already-deployed on-chain accounts.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "check-upgrade": "bin/check-upgrade.mjs"
  },
  "files": [
    "bin",
    "engine",
    "skill",
    "commands",
    "fixtures"
  ],
  "scripts": {
    "postinstall": "node -e \"process.exit(require('fs').existsSync('engine/node_modules/.bin/tsx')?1:0)\" && npm --prefix engine install --omit=dev --no-audit --no-fund --silent || true"
  }
}
